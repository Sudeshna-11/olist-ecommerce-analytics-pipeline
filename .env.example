# Copy this file to `.env` and fill in any values you want to override.
# `.env` is gitignored; this `.env.example` is committed as the template.

# ── Target backend ────────────────────────────────────────────────
# Selects which warehouse the loader writes to. Default: postgres.
# Set to `snowflake` to use the Snowflake backend (week 2+).
TARGET=postgres

# ── Postgres (local Docker, week 1) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=olist
POSTGRES_USER=olist_user
POSTGRES_PASSWORD=olist_pass

# ── Snowflake (week 2) ────────────────────────────────────────────
# Account format: `<orgname>-<accountname>` (single hyphen, NOT a slash).
# Find it in the Snowsight URL: app.snowflake.com/<orgname>/<accountname>/...
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=OLIST
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── Exchange rate API (week 2 — leave blank for now) ──────────────
# FX_API_KEY=
