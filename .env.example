# Copy this file to `.env` and fill in any values you want to override.
# `.env` is gitignored; this `.env.example` is committed as the template.

# ── Postgres (local Docker, week 1) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=olist
POSTGRES_USER=olist_user
POSTGRES_PASSWORD=olist_pass

