# Terraform working files
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Saved plan files can embed sensitive values — never commit
tfplan
*.tfplan

# Account-specific / sensitive inputs — keep only the .example versions
backend.hcl
*.tfvars
!*.tfvars.example

# .terraform.lock.hcl is intentionally committed (pins provider versions)
