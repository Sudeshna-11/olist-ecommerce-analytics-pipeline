# Copy this file to `.secrets.env` and fill in your real secret values.
# `.secrets.env` is gitignored; this `.secrets.env.example` is the template.
#
# Anything genuinely sensitive (passwords, API keys, tokens) goes here.
# Non-secrets (TARGET, hostnames, ports, usernames, warehouse/db names)
# live in `.env`. The loader (src/ingest/config.py) reads `.env` first
# then `.secrets.env` with override=True, so values defined here win.

# ── Postgres (local Docker) ───────────────────────────────────────
POSTGRES_PASSWORD=olist_pass

# ── Snowflake ─────────────────────────────────────────────────────
SNOWFLAKE_PASSWORD=

# ── Exchange rate API (free tier providers like Frankfurter need no key) ─
# FX_API_KEY=
